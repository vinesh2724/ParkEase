        <div style="margin-top:6px;"><span class="tag">🏍️ Bike</span><span class="tag">Open</span></div>
      </div>
      <div style="text-align:right;">
        <div class="spot-price">₹10/hr</div>
        <span class="badge badge-green">Available</span>
        <p style="font-size:12px; color:#888; margin-top:4px;">⭐ 4.4</p>
