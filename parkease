  </div>

  <!-- MAP IS HERE -->
  <div id="map"></div>

  <div style="display:flex; gap:8px; margin-bottom:15px; flex-wrap:wrap;">
    <button class="dur-btn active" onclick="setFilter(this)">All</button>
    <button class="dur-btn" onclick="setFilter(this)">🚗 Car</button>
