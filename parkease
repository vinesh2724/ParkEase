  <button class="btn btn-green" onclick="show('host')">🚀 Publish Listing</button>
</div>

<script>
  // FUNCTION 1: show() - switches between screens
  function show(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo(0, 0);
    // If home screen is shown, refresh the map size
    if (id === 'home' && map) { setTimeout(() => map.invalidateSize(), 200); }
  }

  // FUNCTION 2: setRole() - switches between Seeker and Host
  var role = 'seeker';
  function setRole(r) {
    role = r;
    document.getElementById('seekerBtn').classList.toggle('active', r === 'seeker');
    document.getElementById('hostBtn').classList.toggle('active', r === 'host');
  }

  // FUNCTION 3: login() - validates and navigates
  function login() {
    var email = document.getElementById('emailInput').value;
    var pass  = document.getElementById('passInput').value;
    if (!email || !pass) { alert('Please enter email and password!'); return; }
    show(role === 'host' ? 'host' : 'home');
  }

  // FUNCTION 4: setFilter() - highlights selected filter
  function setFilter(btn) {
    document.querySelectorAll('.dur-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  // FUNCTION 5: setTime() - selects a time slot
  function setTime(el) {
    if (el.classList.contains('taken')) return;
    document.querySelectorAll('.time-slot').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  // FUNCTION 6: setDur() - selects duration
  function setDur(el) {
    document.querySelectorAll('.dur-btn').forEach(d => d.classList.remove('active'));
    el.classList.add('active');
  }

  // FUNCTION 7: setPay() - selects payment method
  function setPay(el) {
    document.querySelectorAll('.pay-option').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
  }

  // Set today's date
  document.getElementById('dateInput').valueAsDate = new Date();

  // MAP SETUP - runs after full page loads
  var map;
  window.onload = function() {
    map = L.map('map').setView([13.0827, 80.2707], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap'
    }).addTo(map);
    var spots = [
      { lat: 13.0418, lng: 80.2341, name: "Ravi's Home Spot", price: "₹15/hr" },
      { lat: 13.0569, lng: 80.2425, name: "Priya's Driveway",  price: "₹10/hr" },
      { lat: 13.0339, lng: 80.2676, name: "Kumar's Garage",    price: "₹12/hr" }
    ];
    spots.forEach(function(spot) {
      L.marker([spot.lat, spot.lng]).addTo(map)
        .bindPopup('<b>' + spot.name + '</b><br/>' + spot.price);
    });
  };
</script>
</body>
</html>
